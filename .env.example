# ─── LLM Provider ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Whisper ────────────────────────────────────────────────────
# tiny=75MB RAM, base=145MB, small=460MB, medium=1.5GB — use tiny on 8GB machine
WHISPER_MODEL=tiny

# ─── MinIO (local S3-compatible storage) ─────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=veda-videos
MINIO_SECURE=false

# ─── Temp local dir (for FFmpeg scratch space) ───────────────────
TEMP_DIR=/tmp/veda

# ─── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=sqlite:///./veda.db

# ─── App ────────────────────────────────────────────────────────
APP_ENV=development
MAX_UPLOAD_SIZE_MB=2000
CLIP_MIN_DURATION=20
CLIP_MAX_DURATION=30
VIRALITY_THRESHOLD=55
